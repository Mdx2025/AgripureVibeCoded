# AgriPure environment — copy to .env.local and fill in your own values.
# Required vars are validated at runtime by src/lib/env.ts (zod). Optional
# integrations stay stubbed until a key is added.
#
# Generate a build without real secrets (CI) by setting SKIP_ENV_VALIDATION=1.

# ============================ REQUIRED ============================

# --- Database (Neon Postgres, AWS us-west-2) ---
# DATABASE_URL = the POOLED connection string (host contains "-pooler"); used by
#   the app at runtime. DATABASE_URL_UNPOOLED = the direct string; used by
#   drizzle-kit migrations (DDL over PgBouncer is unreliable).
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# --- Auth.js (admin login) ---
# Generate: openssl rand -base64 32   (or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=
# Set to true when running behind a proxy (Fly/Cloudflare) so Auth.js trusts the host.
AUTH_TRUST_HOST=true

# ============================ OPTIONAL ============================

# --- Email (Resend) — sends quote link + account login on quote submit ---
RESEND_API_KEY=
EMAIL_FROM="AgriPure <orders@yourdomain.com>"

# --- Stripe (credit-card checkout, orders < $25k) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Plaid (bank / ACH, orders $25k–$50k) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Media (Cloudflare R2) — Phase 2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=agripure-media
NEXT_PUBLIC_MEDIA_BASE_URL=

# --- Observability (Sentry) — Phase 4 ---
SENTRY_DSN=
