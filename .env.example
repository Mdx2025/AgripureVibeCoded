# AgriPure integrations — copy to .env.local and fill in your own keys.
# Everything works stubbed without these; adding a key turns that path live.

# --- Database (Neon serverless Postgres, AWS us-west-2) ---
# Use the POOLED connection string (host contains "-pooler"). Required for
# Drizzle once the data layer migration (Phase 0b) lands.
DATABASE_URL=

# --- Email (Resend) — sends quote link + account login on quote submit ---
RESEND_API_KEY=
EMAIL_FROM="AgriPure <orders@yourdomain.com>"

# --- Stripe (credit-card checkout, orders < $25k) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Plaid (bank / ACH, orders $25k–$50k) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
